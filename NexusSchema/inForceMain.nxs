}

REPORT_FIELD = Table () {
  REPORT_TABLE_ID : @REPORT_TABLE
  AUTOSEARCH: DOM_CHAR
  DATA_TYPE: DOM_NAME
  FIELD_ALIAS: DOM_NAME
  FIELD_NAME: DOM_NAME
  MANDATORY: DOM_CHAR
  SEARCHABLE: DOM_CHAR
  SELECTABLE: DOM_CHAR
  SORTABLE: DOM_CHAR
  TABLE_NAME: DOM_NAME
}

REPORT_JOIN = Table {
  FIELD_DETAIL: DOM_NAME
  FIELD_MASTER: DOM_NAME
  JOIN_TYPE: DOM_NAME
  OPERATORS: DOM_NAME
  TABLE_DETAIL: DOM_NAME
  TABLE_MASTER: DOM_NAME
}
  
INVOICE_TEMPLATE = Table(TMPL_TRACKED)
QUOTE_TEMPLATE = Table(TMPL_TRACKED)
RESOURCE = Table(TMPL_TRACKED)



CUSTOM = Table(TMPL_TRACKED) {
  BASE_TABLE_ID : @REPORT_TABLE
  NAME : DOM_NAME
  PRIMARY_KEY_NAME : DOM_NAME
  FOREIGN_KEY_NAME : DOM_NAME
}

CUSTOM_PIVOT = Table(TMPL_TRACKED) {
  BASE_TABLE_ID : @REPORT_TABLE
  NAME : DOM_NAME
  PRIMARY_KEY_NAME : DOM_NAME
  FOREIGN_KEY_NAME : DOM_NAME
  PIVOT_TABLE_ID : @REPORT_TABLE
  BASE_FIELD_ID : @REPORT_FIELD
  PIVOT_TABLE_VALUE : DOM_INDEX
}

CUSTOM_FIELDS = Table(TMPL_TRACKED) {
  CUSTOM_ID : @CUSTOM
  DISPLAY_NAME : DOM_NAME
  DOM_NAME : DOM_NAME
  FIELD_NAME : DOM_NAME
  FIELD_TYPE : DOM_NAME
  FIELD_SIZE : DOM_COUNT
}

CUSTOM_PIVOT_FIELDS = Table(TMPL_TRACKED) {
  CUSTOM_PIVOT_ID : @CUSTOM_PIVOT
  DISPLAY_NAME : DOM_NAME
  DOM_NAME : DOM_NAME
  FIELD_NAME : DOM_NAME
  FIELD_TYPE : DOM_NAME
  FIELD_SIZE : DOM_COUNT
}

