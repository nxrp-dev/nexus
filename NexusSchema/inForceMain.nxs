CoreTypes = Type {
  DOM_CUSTOM_235  : "varchar(235)"
  DOM_ACCOUNT_NUMBER : "varchar(100)"
  DOM_ADDRESS : "varchar(200)"
  DOM_AGE : "smallint"
  DOM_BOOLEAN : "smallint"
  DOM_CAPTION : "varchar(50)"
  DOM_CHAR : "char(1)"
  DOM_CITY : "varchar(100)"
  DOM_CODE : "varchar(6)"
  DOM_COLOR : "integer"
  DOM_COLUMNS : "smallint"
  DOM_COMMENT : "blob sub_type 1 segment size 100"
  DOM_COUNT : "integer"
  DOM_COUNTY : "varchar(100)"
  DOM_COUNTRY : "varchar(100)"
  DOM_CPC : "varchar(30)"
  DOM_DATE : "Date"
  DOM_DAY : "smallint"
  DOM_DESCRIPTION : "blob sub_type 1 segment size 100"
  DOM_DIGITS : "smallint"
  DOM_DL_NUMBER : "varchar(100)"
  DOM_DOMAIN : "varchar(100)"
  DOM_EMAIL : "varchar(200)"
  DOM_ENUMERATOR_NAME : "varchar(100)"
  DOM_FILE_ATTACHMENT : "blob sub_type 0 segment size 80"
  DOM_FLOAT : "float"
  DOM_GENDER : "varchar(1)"
  DOM_HOURS : "Numeric(8,2)"
  DOM_INCHES : "Numeric(4,2)"
  DOM_INDEX : "integer"
  DOM_INTEGER : "integer"
  DOM_LOCATION : "varchar(40)"
  DOM_MONEY : "Double Precision"
  DOM_NAME : "varchar(100)"
  DOM_NAME_PREFIX : "varchar(10)"
  DOM_NAME_SUFFIX : "varchar(15)"
  DOM_PASSWORD : "varchar(50)"
  DOM_PERCENT : "Numeric(4,2)"
  DOM_PHONE : "varchar(13)"
  DOM_PRIMARY_INDEX : "integer"
  DOM_REPORT_TMPL : "blob sub_type 0 segment size 400"
  DOM_SHORT_GUID : "char(32)"
  DOM_SIZE : "integer"
  DOM_SSN : "varchar(13)"
  DOM_STATE : "char(2)"
  DOM_SUFFIX : "varchar(15)"
  DOM_TAX_ID : "varchar(15)"
  DOM_TIME : "time"
  DOM_TIMESTAMP : "timestamp"
  DOM_TYPE : "smallint"
  DOM_UPC : "varchar(20)"
  DOM_URL : "varchar(255)"
  DOM_USERNAME : "varchar(20)"
  DOM_YEAR : "smallint"
  DOM_ZIPCODE : "varchar(10)"
}

ATTR_HISTORY = Attributes {
  IS_HISTORY : "True"
}

TMPL_ADDRESS = Template {
  ADDRESS_TYPE_ID : @ADDRESS_TYPE
  ADDRESS_LINE_1 : DOM_ADDRESS
  ADDRESS_LINE_2 : DOM_ADDRESS
  CITY : DOM_CITY
  STATE : DOM_STATE
  COUNTY : DOM_COUNTY
  COUNTRY : DOM_COUNTRY
  ZIPCODE : DOM_ZIPCODE
}

TMPL_CONTACT_INFORMATION = Template {
  ADDRESS_LINE_1 : DOM_ADDRESS
  ADDRESS_LINE_2 : DOM_ADDRESS
  CITY : DOM_CITY
  STATE : DOM_STATE
  COUNTY : DOM_COUNTY
  COUNTRY : DOM_COUNTRY
  ZIPCODE : DOM_ZIPCODE
  PHONE : DOM_PHONE
}

TMPL_DATED = Template {
  EFFECTIVE_DATE : DOM_TIMESTAMP
  EXPIRATION_DATE : DOM_TIMESTAMP
}

TMPL_DIMENSIONS = Template {
  HEIGHT : DOM_SIZE
  WIDTH : DOM_SIZE
  DEPTH : DOM_SIZE
}

TMPL_DISCOUNT = Template {
  FLAT_COST : DOM_MONEY
  PERCENT : DOM_PERCENT
}

TMPL_EMAIL = Template {
  EMAIL : DOM_EMAIL
  EMAIL_TYPE_ID : @EMAIL_TYPE
}

TMPL_FILE = Template {
  FILE_VERSION : DOM_COUNT
  FILENAME : DOM_NAME
  FILE_ATTACHMENT : DOM_FILE_ATTACHMENT
}


TMPL_NOTE = Template {
  NOTE : DOM_COMMENT
}

TMPL_PHONE = Template {
  PHONE : DOM_PHONE
  PHONE_TYPE_ID : @PHONE_TYPE
}

TMPL_TRACKED = Template {
  CREATED_BY : @PERSON
  CREATED_DATE : DOM_TIMESTAMP
  MODIFIED_BY : @PERSON
  MODIFIED_DATE : DOM_TIMESTAMP
}

TMPL_TYPE = Template {
  NAME : DOM_NAME
  DESCRIPTION : DOM_DESCRIPTION
  SORT_ORDER : DOM_COUNT
}

ACTIVITY = Table(TMPL_DATED, TMPL_TRACKED){
